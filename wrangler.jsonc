{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "billetera",
  "main": "worker.js",
  "compatibility_date": "2025-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
